@page "/sobre-nosotros"
@using Microsoft.Extensions.Localization
@using IASD_Magnolia.Resources
@inject IStringLocalizer<AboutResource> L

<PageTitle>@L["Title"] - IASD Magnolia</PageTitle>

<section class="about-hero-section">
    <div class="about-hero-overlay">
        <div class="about-hero-content">
            <h1>@L["Title"]</h1>
            <p class="about-subtitle">@L["Subtitle"]</p>
            <p class="about-description">@L["Description"]</p>
        </div>
    </div>
</section>

<hr />

<section class="pillars-section">
    <div class="pillars-container">
        <div class="pillar-card">
            <div class="pillar-icon">
                <i class="bi bi-bullseye"></i>
            </div>
            <h3>@L["MissionTitle"]</h3>
            <p>@L["MissionText"]</p>
        </div>

        <div class="pillar-card">
            <div class="pillar-icon">
                <i class="fa-solid fa-eye"></i>
            </div>
            <h3>@L["VisionTitle"]</h3>
            <p>@L["VisionText"]</p>
        </div>

        <div class="pillar-card">
            <div class="pillar-icon">
                <i class="fa-regular fa-heart"></i>
            </div>
            <h3>@L["PurposeTitle"]</h3>
            <p>@L["PurposeText"]</p>
        </div>

        <div class="pillar-card">
            <div class="pillar-icon">
                <i class="fa-solid fa-book-open-reader"></i>
            </div>
            <h3>@L["MottoTitle"]</h3>
            <p>@L["MottoText"]</p>
            <p class="pillar-verse">Juan 3:16</p>
        </div>
    </div>
</section>

<section class="history-section">
    <h2>@L["HistoryTitle"]</h2>
    <p class="history-intro">@L["HistoryIntro"]</p>

    <div class="timeline">
        <div class="timeline-item">
            <div class="timeline-icon">
                <i class="fa-regular fa-calendar"></i>
            </div>
            <h4>1863</h4>
            <p>@L["History1863"]</p>
        </div>

        <div class="timeline-item">
            <div class="timeline-icon">
                <i class="fa-solid fa-users"></i>
            </div>
            <h4>@L["GrowthTitle"]</h4>
            <p>@L["GrowthText"]</p>
        </div>

        <div class="timeline-item">
            <div class="timeline-icon">
                <i class="fa-solid fa-heart-pulse"></i>
            </div>
            <h4>@L["ServiceTitle"]</h4>
            <p>@L["ServiceText"]</p>
        </div>

        <div class="timeline-item">
            <div class="timeline-icon">
                <i class="fa-solid fa-earth-americas"></i>
            </div>
            <h4>@L["WorldMissionTitle"]</h4>
            <p>@L["WorldMissionText"]</p>
        </div>
    </div>
</section>

<section class="beliefs-section">
    <div class="beliefs-container">
        <div class="beliefs-content">
            <h2>@L["BeliefsTitle"]</h2>
            <p class="beliefs-intro">@L["BeliefsIntro"]</p>

            <div class="beliefs-grid">
                <div class="belief-item">
                    <div class="pillar-icon">
                        <i class="fa-solid fa-book-bible"></i>
                    </div>
                    <p>@L["BeliefBible"]</p>
                </div>

                <div class="belief-item">
                    <div class="pillar-icon">
                        <i class="fa-solid fa-cross"></i>
                    </div>
                    <p>@L["BeliefSalvation"]</p>
                </div>

                <div class="belief-item">
                    <div class="belief-icon">
                        <img src="/img/AboutUs/FooterLogo.png" alt="@L["BeliefSabbath"]" />
                    </div>
                    <p>@L["BeliefSabbath"]</p>
                </div>

                <div class="belief-item">
                    <div class="pillar-icon">
                        <i class="fa-solid fa-book-bible"></i>
                    </div>
                    <p>@L["BeliefSecondComing"]</p>
                </div>

                <div class="belief-item">
                    <div class="pillar-icon">
                        <i class="fa-solid fa-church"></i>
                    </div>
                    <p>@L["BeliefSanctuary"]</p>
                </div>

                <div class="belief-item">
                    <div class="pillar-icon">
                        <i class="fa-solid fa-users"></i>
                    </div>
                    <p>@L["BeliefChurch"]</p>
                </div>

                <div class="belief-item">
                    <div class="pillar-icon">
                        <i class="fa-solid fa-earth-americas"></i>
                    </div>
                    <p>@L["BeliefMission"]</p>
                </div>
            </div>
        </div>

        <div class="beliefs-image">
            <img src="/img/AboutUs/Biblia.png" alt="@L["BibleImageAlt"]" />
        </div>
    </div>
</section>
