@page "/admin/login"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using IASD_Magnolia.Services
@using IASD_Magnolia.Models
@inject AuthService AuthService
@inject AuthStateService AuthState
@inject NavigationManager Navigation
@inject ILogger<Login> Logger

<PageTitle>Login - IASD Magnolia</PageTitle>

<div class="login-page">
    <div class="login-container">
        <!-- Left Side - Welcome -->
        <div class="login-left">
            <div class="welcome-content">
                <h2>Bienvenido de nuevo 👋</h2>
                <p>Gestiona los eventos y la información de nuestra iglesia de manera fácil y segura.</p>

                <div class="quote-section">
                    <div class="quote-icon">"</div>
                    <p class="quote-text">"Todo lo puedo en Cristo que me fortalece."</p>
                    <p class="quote-reference">Filipenses 4:13</p>
                </div>
            </div>
        </div>

        <!-- Right Side - Login Form -->
        <div class="login-right">
            <div class="login-form-container">
                <div class="logo-section">
                    <div class="logo-circle">
                        <i class="fas fa-church"></i>
                    </div>
                    <h1>IASD Magnolia</h1>
                    <p class="subtitle">Panel de Administración</p>
                </div>

                <div class="form-section">
                    <h2>Iniciar sesión</h2>
                    <p class="form-description">Ingresa tus credenciales para acceder al panel de administración.</p>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger" role="alert">
                            <i class="fas fa-exclamation-circle me-2"></i>@errorMessage
                        </div>
                    }

                    <EditForm Model="loginModel" OnValidSubmit="HandleLogin" FormName="loginForm">
                        <DataAnnotationsValidator />

                        <div class="form-group">
                            <label for="emailOrUsername">Correo electrónico o nombre de usuario</label>
                            <div class="input-with-icon">
                                <i class="fas fa-user"></i>
                                <InputText id="emailOrUsername" 
                                          class="form-control" 
                                          @bind-Value="loginModel.EmailOrUsername"/>
                                          @* placeholder="usuario@iasdmagnolia.org o usuario" /> *@
                            </div>
                            <ValidationMessage For="@(() => loginModel.EmailOrUsername)" class="text-danger" />
                        </div>

                        <div class="form-group">
                            <label for="password">Contraseña</label>
                            <div class="input-with-icon">
                                <i class="fas fa-lock"></i>
                                <InputText id="password" 
                                          type="@(showPassword ? "text" : "password")" 
                                          class="form-control" 
                                          @bind-Value="loginModel.Password" 
                                          placeholder="••••••••••••" />
                                <button type="button" 
                                        class="btn-toggle-password" 
                                        @onclick="TogglePasswordVisibility">
                                    <i class="fas @(showPassword ? "fa-eye-slash" : "fa-eye")"></i>
                                </button>
                            </div>
                            <ValidationMessage For="@(() => loginModel.Password)" class="text-danger" />
                        </div>

                        <div class="form-group-checkbox">
                            <label>
                                <InputCheckbox @bind-Value="loginModel.RememberMe" />
                                <span>Recordarme</span>
                            </label>
                        </div>

                        <button type="submit" class="btn-login" disabled="@isLoading">
                            @if (isLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                <span>Iniciando sesión...</span>
                            }
                            else
                            {
                                <i class="fas fa-sign-in-alt me-2"></i>
                                <span>Iniciar sesión</span>
                            }
                        </button>
                    </EditForm>
                </div>

                <div class="footer-text">
                    © @DateTime.Now.Year IASD Magnolia. Todos los derechos reservados.
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private LoginModel loginModel = new();
    private string errorMessage = string.Empty;
    private bool isLoading = false;
    private bool showPassword = false;

    private class LoginModel
    {
        [Required(ErrorMessage = "El correo electrónico o nombre de usuario es requerido")]
        public string EmailOrUsername { get; set; } = string.Empty;

        [Required(ErrorMessage = "La contraseña es requerida")]
        [MinLength(6, ErrorMessage = "La contraseña debe tener al menos 6 caracteres")]
        public string Password { get; set; } = string.Empty;

        public bool RememberMe { get; set; }
    }

    private async Task HandleLogin()
    {
        errorMessage = string.Empty;
        isLoading = true;

        try
        {
            var user = await AuthService.LoginAsync(loginModel.EmailOrUsername, loginModel.Password);

            if (user != null)
            {

                // Guardar la sesión del usuario
                await AuthState.SetUserAsync(user);


                // Esperar un poco para asegurar que se guarde
                await Task.Delay(500);

                // Navegar sin forceLoad para mantener el estado
                Navigation.NavigateTo("/", false);
            }
            else
            {
                errorMessage = "Correo electrónico o contraseña incorrectos";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Error al iniciar sesión. Por favor, intenta nuevamente.";
            Logger.LogError(ex, "Error during login attempt.");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void TogglePasswordVisibility()
    {
        showPassword = !showPassword;
    }
}
