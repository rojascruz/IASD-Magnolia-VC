@page "/admin/usuarios/editar/{UserId:guid}"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using IASD_Magnolia.Services
@using IASD_Magnolia.Models
@using IASD_Magnolia.Components.Admin
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ILogger<Editar> Logger

<PageTitle>Editar Usuario - IASD Magnolia</PageTitle>

<AdminAuthRequired>
    <div class="admin-page">
        <div class="container py-4" style="max-width: 800px;">
            <!-- Header -->
            <div class="evento-page-header">
                <button class="btn-volver" @onclick="@(() => Navigation.NavigateTo("/admin/usuarios"))">
                    <i class="fas fa-arrow-left"></i>
                    <span>Volver</span>
                </button>
                <div class="header-icon-circle">
                    <i class="fas fa-user-edit"></i>
                </div>
                <div class="header-text" >
                    <h1 class="evento-page-title">Editar Usuario</h1>
                    <p class="evento-page-subtitle">
                        Actualiza la información del usuario en el sistema.
                    </p>
                </div>
            </div>

            @if (isLoadingUser)
            {
                <div class="card shadow-sm">
                    <div class="card-body p-5 text-center">
                        <div class="spinner-border text-primary mb-3" role="status">
                            <span class="visually-hidden">Cargando...</span>
                        </div>
                        <p class="text-muted">Cargando información del usuario...</p>
                    </div>
                </div>
            }
            else if (editModel == null)
            {
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-circle me-2"></i>
                    No se pudo cargar la información del usuario.
                    <button class="btn btn-link" @onclick="GoBack">Volver</button>
                </div>
            }
            else
            {
                <!-- Form Card -->
                <div class="card shadow-sm">
                    <div class="card-body p-4">
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert alert-danger" role="alert">
                                <i class="fas fa-exclamation-circle me-2"></i>@errorMessage
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(successMessage))
                        {
                            <div class="alert alert-success" role="alert">
                                <i class="fas fa-check-circle me-2"></i>@successMessage
                            </div>
                        }

                        <EditForm Model="editModel" OnValidSubmit="HandleUpdate" FormName="editUserForm">
                            <DataAnnotationsValidator />

                            <!-- Información básica -->
                            <div class="form-section mb-4">
                                <h5 class="section-title mb-3">Información básica</h5>

                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label for="fullName" class="form-label required">Nombre completo</label>
                                        <InputText id="fullName" 
                                                  class="form-control" 
                                                  @bind-Value="editModel.FullName" 
                                                  placeholder="Ej. Juan Pérez" />
                                        <ValidationMessage For="@(() => editModel.FullName)" class="text-danger" />
                                    </div>

                                    <div class="col-md-6">
                                        <label for="email" class="form-label required">Correo electrónico</label>
                                        <InputText id="email" 
                                                  type="email"
                                                  class="form-control" 
                                                  @bind-Value="editModel.Email" 
                                                  placeholder="ejemplo@iasdmagnolia.org" />
                                        <ValidationMessage For="@(() => editModel.Email)" class="text-danger" />
                                    </div>

                                    <div class="col-md-6">
                                        <label for="username" class="form-label required">Nombre de usuario</label>
                                        <InputText id="username" 
                                                  class="form-control" 
                                                  @bind-Value="editModel.Username" 
                                                  placeholder="ej. juanperez" />
                                        <small class="form-text text-muted">Este será el nombre de usuario para iniciar sesión.</small>
                                        <ValidationMessage For="@(() => editModel.Username)" class="text-danger" />
                                    </div>

                                    <div class="col-md-6">
                                        <label for="phone" class="form-label">Teléfono (opcional)</label>
                                        <InputText id="phone" 
                                                  class="form-control" 
                                                  @bind-Value="editModel.Phone" 
                                                  placeholder="Ej. (787) 123-4567" />
                                    </div>
                                </div>
                            </div>

                            <!-- Cambiar contraseńa (opcional) -->
                            <div class="form-section mb-4">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h5 class="section-title mb-0">Cambiar contraseńa</h5>
                                    <div class="form-check form-switch">
                                        <input class="form-check-input" type="checkbox" id="changePassword" @bind="showPasswordFields">
                                        <label class="form-check-label" for="changePassword">
                                            Cambiar contraseńa
                                        </label>
                                    </div>
                                </div>

                                @if (showPasswordFields)
                                {
                                    <div class="alert alert-info mb-3">
                                        <i class="fas fa-info-circle me-2"></i>
                                        <small>Deja estos campos vacíos si no deseas cambiar la contraseńa.</small>
                                    </div>

                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label for="password" class="form-label">Nueva contraseńa</label>
                                            <div class="input-group">
                                                <span class="input-group-text bg-white">
                                                    <i class="fas fa-lock"></i>
                                                </span>
                                                <InputText id="password" 
                                                          type="@(showPassword ? "text" : "password")"
                                                          class="form-control border-start-0" 
                                                          @bind-Value="editModel.Password" 
                                                          placeholder="••••••••••••" />
                                                <button type="button" 
                                                        class="btn btn-outline-secondary"
                                                        @onclick="TogglePasswordVisibility">
                                                    <i class="fas @(showPassword ? "fa-eye-slash" : "fa-eye")"></i>
                                                </button>
                                            </div>
                                            <small class="form-text text-muted">Mínimo 8 caracteres.</small>
                                            @if (!string.IsNullOrEmpty(editModel.Password))
                                            {
                                                <ValidationMessage For="@(() => editModel.Password)" class="text-danger" />
                                            }
                                        </div>

                                        <div class="col-md-6">
                                            <label for="confirmPassword" class="form-label">Confirmar contraseńa</label>
                                            <div class="input-group">
                                                <span class="input-group-text bg-white">
                                                    <i class="fas fa-lock"></i>
                                                </span>
                                                <InputText id="confirmPassword" 
                                                          type="@(showConfirmPassword ? "text" : "password")"
                                                          class="form-control border-start-0" 
                                                          @bind-Value="editModel.ConfirmPassword" 
                                                          placeholder="••••••••••••" />
                                                <button type="button" 
                                                        class="btn btn-outline-secondary"
                                                        @onclick="ToggleConfirmPasswordVisibility">
                                                    <i class="fas @(showConfirmPassword ? "fa-eye-slash" : "fa-eye")"></i>
                                                </button>
                                            </div>
                                            <small class="form-text text-muted">Repite la contraseńa.</small>
                                            @if (!string.IsNullOrEmpty(editModel.ConfirmPassword))
                                            {
                                                <ValidationMessage For="@(() => editModel.ConfirmPassword)" class="text-danger" />
                                            }
                                        </div>
                                    </div>
                                }
                            </div>

                            <!-- Rol y permisos -->
                            <div class="form-section mb-4">
                                <h5 class="section-title mb-3">Rol y permisos</h5>

                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label for="role" class="form-label required">Rol</label>
                                        <InputSelect id="role" class="form-select" @bind-Value="editModel.RoleId">
                                            <option value="">Selecciona un rol</option>
                                            @foreach (var role in roles)
                                            {
                                                <option value="@role.Id">@role.Name</option>
                                            }
                                        </InputSelect>
                                        <small class="form-text text-muted">Define el nivel de acceso del usuario en el sistema.</small>
                                        <ValidationMessage For="@(() => editModel.RoleId)" class="text-danger" />
                                    </div>

                                    <div class="col-md-6">
                                        <label class="form-label">Estado</label>
                                        <div class="form-check form-switch mt-2">
                                            <InputCheckbox id="isActive" class="form-check-input" @bind-Value="editModel.IsActive" />
                                            <label class="form-check-label" for="isActive">
                                                @(editModel.IsActive ? "Activo" : "Inactivo")
                                            </label>
                                        </div>
                                        <small class="form-text text-muted">El usuario podrá acceder al sistema.</small>
                                    </div>
                                </div>

                                <!-- Info de roles -->
                                <div class="alert alert-info mt-3 mb-0">
                                    <div class="small">
                                        <i class="fas fa-info-circle me-2"></i>
                                        <strong>Roles disponibles:</strong>
                                        <ul class="mb-0 mt-2">
                                            <li><strong>Administrador:</strong> Acceso completo al sistema.</li>
                                            <li><strong>Editor:</strong> Puede gestionar eventos y contenido.</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>

                            <!-- Información adicional -->
                            <div class="form-section mb-4">
                                <h5 class="section-title mb-3">Información del sistema</h5>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label text-muted">Fecha de registro</label>
                                        <p class="form-control-plaintext">@originalUser?.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label text-muted">Último acceso</label>
                                        <p class="form-control-plaintext">
                                            @if (originalUser?.LastLoginAt.HasValue == true)
                                            {
                                                @originalUser.LastLoginAt.Value.ToString("dd/MM/yyyy HH:mm")
                                            }
                                            else
                                            {
                                                <span>Nunca</span>
                                            }
                                        </p>
                                    </div>
                                </div>
                            </div>

                            <!-- Buttons -->
                            <div class="form-actions-simple">
                                <button type="button" class="btn-delete-simple" @onclick="ConfirmDelete">
                                    <i class="fas fa-trash me-2"></i>Eliminar usuario
                                </button>
                                <div class="actions-right">
                                    <button type="button" class="btn-cancel-simple" @onclick="GoBack">
                                        <i class="fas fa-times me-2"></i>Cancelar
                                    </button>
                                    <button type="submit" class="btn-submit-simple" disabled="@isSaving">
                                        @if (isSaving)
                                        {
                                            <span class="spinner-border spinner-border-sm me-2"></span>
                                        }
                                        else
                                        {
                                            <i class="fas fa-save me-2"></i>
                                        }
                                        Guardar cambios
                                    </button>
                                </div>
                            </div>
                        </EditForm>
                    </div>
                </div>
            }
        </div>
    </div>
</AdminAuthRequired>

@code {
    [Parameter]
    public Guid UserId { get; set; }

    private EditUserModel? editModel;
    private User? originalUser;
    private List<Role> roles = new();
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;
    private bool isSaving = false;
    private bool isLoadingUser = true;
    private bool showPassword = false;
    private bool showConfirmPassword = false;
    private bool showPasswordFields = false;

    private class EditUserModel
    {
        [Required(ErrorMessage = "El nombre completo es requerido")]
        public string FullName { get; set; } = string.Empty;

        [Required(ErrorMessage = "El nombre de usuario es requerido")]
        [MinLength(3, ErrorMessage = "El nombre de usuario debe tener al menos 3 caracteres")]
        public string Username { get; set; } = string.Empty;

        [Required(ErrorMessage = "El correo electrónico es requerido")]
        [EmailAddress(ErrorMessage = "Ingresa un correo electrónico válido")]
        public string Email { get; set; } = string.Empty;

        public string? Phone { get; set; }

        [MinLength(8, ErrorMessage = "La contraseńa debe tener al menos 8 caracteres")]
        public string? Password { get; set; }

        [Compare(nameof(Password), ErrorMessage = "Las contraseńas no coinciden")]
        public string? ConfirmPassword { get; set; }

        [Required(ErrorMessage = "Debes seleccionar un rol")]
        [Range(1, int.MaxValue, ErrorMessage = "Debes seleccionar un rol válido")]
        public int RoleId { get; set; }

        public bool IsActive { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadRoles();
        await LoadUser();
    }

    private async Task LoadRoles()
    {
        try
        {
            roles = await AuthService.GetRolesAsync();
        }
        catch (Exception ex)
        {
            errorMessage = "Error al cargar los roles";
            Logger.LogError(ex, "Error loading roles.");
        }
    }

    private async Task LoadUser()
    {
        isLoadingUser = true;
        try
        {
            var users = await AuthService.GetAllUsersAsync();
            originalUser = users.FirstOrDefault(u => u.Id == UserId);

            if (originalUser != null)
            {
                editModel = new EditUserModel
                {
                    FullName = originalUser.FullName,
                    Username = originalUser.Username ?? string.Empty,
                    Email = originalUser.Email,
                    Phone = originalUser.Phone,
                    RoleId = originalUser.RoleId,
                    IsActive = originalUser.IsActive
                };
            }
            else
            {
                errorMessage = "Usuario no encontrado";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Error al cargar el usuario";
            Logger.LogError(ex, "Error loading user.");
            
        }
        finally
        {
            isLoadingUser = false;
        }
    }

    private async Task HandleUpdate()
    {
        if (editModel == null) return;

        errorMessage = string.Empty;
        successMessage = string.Empty;
        isSaving = true;

        try
        {
            // Actualizar información básica
            var (success, message) = await AuthService.UpdateUserAsync(
                userId: UserId,
                fullName: editModel.FullName,
                username: editModel.Username,
                email: editModel.Email,
                phone: editModel.Phone,
                roleId: editModel.RoleId,
                isActive: editModel.IsActive
            );

            if (!success)
            {
                errorMessage = message;
                return;
            }

            // Si se proporcionó una nueva contraseńa, actualizarla
            if (showPasswordFields && !string.IsNullOrWhiteSpace(editModel.Password))
            {
                var (passwordSuccess, passwordMessage) = await AuthService.ChangePasswordAsync(
                    UserId,
                    editModel.Password
                );

                if (!passwordSuccess)
                {
                    errorMessage = $"Usuario actualizado, pero error al cambiar contraseńa: {passwordMessage}";
                    return;
                }
            }

            successMessage = "Usuario actualizado exitosamente";
            await Task.Delay(1500);
            Navigation.NavigateTo("/admin/usuarios");
        }
        catch (Exception ex)
        {
            errorMessage = "Error al actualizar el usuario. Por favor, intenta nuevamente.";
            Logger.LogError(ex, "Error updating user.");
        }
        finally
        {
            isSaving = false;
        }
    }

    private void TogglePasswordVisibility()
    {
        showPassword = !showPassword;
    }

    private void ToggleConfirmPasswordVisibility()
    {
        showConfirmPassword = !showConfirmPassword;
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/admin/usuarios");
    }

    private async Task ConfirmDelete()
    {
        if (originalUser == null) return;

        var confirmed = await JS.InvokeAsync<bool>("confirm", 
            $"żEstás seguro de eliminar al usuario '{originalUser.FullName}'?\\n\\nEsta acción no se puede deshacer.");

        if (confirmed)
        {
            try
            {
                var (success, message) = await AuthService.DeleteUserAsync(UserId);
                if (success)
                {
                    successMessage = "Usuario eliminado exitosamente";
                    await Task.Delay(1500);
                    Navigation.NavigateTo("/admin/usuarios");
                }
                else
                {
                    errorMessage = message;
                }
            }
            catch (Exception ex)
            {
                errorMessage = $"Error al eliminar: {ex.Message}";
                Logger.LogError(ex, "Error deleting user.");
            }
        }
    }
}
