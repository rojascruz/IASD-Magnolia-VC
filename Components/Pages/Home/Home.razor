@page "/"
@using IASD_Magnolia.Components.Shared
@using IASD_Magnolia.Models
@using Microsoft.Extensions.Localization
@using IASD_Magnolia.Resources
@inject IASD_Magnolia.Services.EventsService EventsService
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Nav.Home"] - IASD Magnolia</PageTitle>

<section class="hero-section">
    <div class="hero-container">

        <div class="hero-content">
            <h1>
                @L["Home.HeroTitle1"]<br />
                <span class="highlight">@L["Home.HeroTitle2"]</span>
            </h1>

            <p>@L["Home.HeroSubtitle"]</p>

            <div class="hero-buttons">
                <a href="/eventos" class="btn-primary">
                    <i class="fa-regular fa-calendar"></i>
                    @L["Home.UpcomingEvents"]
                </a>

                <a href="/clubes" class="hero-btn-secondary">
                    @L["Nav.Club"]
                </a>
            </div>
        </div>

        <div class="hero-verse-wrapper">
            <VersiculoDelDia />
        </div>

    </div>
</section>

<section class="icons-section">
    <div class="icons-container">

        <div class="icon-item">
            <div class="pillar-icon">
                <i class="fa-solid fa-users"></i>
            </div>
            <h3>@L["Home.Community"]</h3>
            <p>@L["Home.CommunitySubtitle"]</p>
        </div>

        <div class="icon-item">
            <div class="pillar-icon">
                <i class="fa-solid fa-book-open"></i>
            </div>
            <h3>@L["Home.Growth"]</h3>
            <p>@L["Home.GrowthSubtitle"]</p>
        </div>

        <div class="icon-item">
            <div class="pillar-icon">
                <i class="fa-regular fa-heart"></i>
            </div>
            <h3>@L["Home.Service"]</h3>
            <p>@L["Home.ServiceSubtitle"]</p>
        </div>

        <div class="icon-item">
            <div class="pillar-icon">
                <i class="fa-solid fa-hand-holding-heart"></i>
            </div>
            <h3>@L["Home.Mission"]</h3>
            <p>@L["Home.MissionSubtitle"]</p>
        </div>

        <div class="icon-item">
            <div class="pillar-icon">
                <i class="fa-solid fa-earth-americas"></i>
            </div>
            <h3>@L["Home.Hope"]</h3>
            <p>@L["Home.HopeSubtitle"]</p>
        </div>

    </div>
</section>

<section class="eventos-section">
    <div class="section-header">
        <h2>@L["Home.UpcomingEvents"]</h2>

        <a href="/eventos" class="link-ver-todos">
            @L["Home.ViewAllEvents"]
            <i class="fa-solid fa-arrow-right-long"></i>
        </a>
    </div>

    <div class="eventos-grid">
        @if (isLoadingEvents)
        {
            <div class="eventos-loading">
                <p>@L["Home.Loading"]</p>
            </div>
        }
        else if (eventos != null && eventos.Any())
        {
            @foreach (var evento in eventos)
            {
                <div class="evento-card" style="background-image: url('@evento.DisplayImage');">
                    <div class="evento-fecha">
                        <span class="dia">@evento.Day</span>
                        <span class="mes">@evento.Month</span>
                    </div>

                    <div class="evento-info">
                        @if (!string.IsNullOrEmpty(evento.EventTypeName))
                        {
                            <span class="evento-tipo" style="background-color: @evento.TypeColorClass">
                                @evento.EventTypeName.ToUpper()
                            </span>
                        }

                        <h3>@evento.Title</h3>

                        @if (!string.IsNullOrEmpty(evento.FormattedTime))
                        {
                            <p class="hora">
                                <i class="fa-regular fa-clock"></i>
                                @evento.FormattedTime
                            </p>
                        }

                        @if (!string.IsNullOrEmpty(evento.DisplayLocation))
                        {
                            <p class="ubicacion">
                                <i class="fa-solid fa-location-dot"></i>
                                @evento.DisplayLocation
                            </p>
                        }

                        @if (!string.IsNullOrEmpty(evento.ShortDescription))
                        {
                            <p>@evento.ShortDescription</p>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="eventos-empty">
                <p>@L["Home.NoEvents"]</p>
                <p>@L["Home.NoEventsSubtitle"]</p>
            </div>
        }
    </div>
</section>

<section class="culto-section">
    <div class="section-header">
        <h2>@L["Home.WorshipDays"]</h2>
    </div>

    <div class="culto-grid">

        <div class="culto-card">
            <p class="culto-dia">@L["Days.Monday"]</p>
            <div class="pillar-icon">
                <i class="fa-solid fa-hands-praying"></i>
            </div>
            <h3 class="culto-nombre">@L["Home.PrayerNight"]</h3>
            <div class="culto-separator"></div>
            <p class="culto-hora">8:00 PM</p>
        </div>

        <div class="culto-card">
            <p class="culto-dia">@L["Days.Wednesday"]</p>
            <div class="pillar-icon">
                <i class="fa-solid fa-moon"></i>
            </div>
            <h3 class="culto-nombre">@L["Home.TestimonyNight"]</h3>
            <div class="culto-separator"></div>
            <p class="culto-hora">8:00 PM</p>
        </div>

        <div class="culto-card">
            <p class="culto-dia">@L["Days.Friday"]</p>
            <div class="pillar-icon">
                <i class="fa-solid fa-people-group"></i>
            </div>
            <h3 class="culto-nombre">@L["Home.YouthSociety"]</h3>
            <div class="culto-separator"></div>
            <p class="culto-hora">8:00 PM</p>
        </div>

        <div class="culto-card">
            <p class="culto-dia">@L["Days.Saturday"]</p>
            <div class="pillar-icon">
                <i class="fa-solid fa-church"></i>
            </div>
            <h3 class="culto-nombre">@L["Home.SabbathSchool"]</h3>
            <div class="culto-separator"></div>
            <p class="culto-hora">9:30 AM</p>

            <h3 class="culto-nombre culto-nombre-second">@L["Home.DivineFellowship"]</h3>
            <div class="culto-separator"></div>
            <p class="culto-hora">11:00 AM</p>
        </div>

    </div>
</section>

@code {
    private List<EventWithType>? eventos;
    private bool isLoadingEvents = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            eventos = await EventsService.GetUpcomingEventsWithTypeAsync(limit: 4);
        }
        catch (Exception)
        {
            eventos = new List<EventWithType>();
        }
        finally
        {
            isLoadingEvents = false;
        }
    }
}