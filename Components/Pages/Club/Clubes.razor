@page "/clubes"
@using IASD_Magnolia.Services
@using IASD_Magnolia.Models
@using IASD_Magnolia.Resources
@inject LeadershipService LeadershipService

@inject IStringLocalizer<ClubsResource> L


<PageTitle>@L["PageTitle"] - IASD Magnolia</PageTitle>

<div class="clubes-page">

    <section class="clubes-hero">
        <div class="clubes-hero-overlay">
            <div class="clubes-hero-content">

                <h1>@L["HeroTitle"]</h1>

                <p class="clubes-subtitle">
                    @L["HeroSubtitle"]
                </p>

                <a href="https://forms.gle/r49u7khmEvCzmQhZA"
                   target="_blank"
                   rel="noopener noreferrer"
                   class="club-register-btn">

                    <i class="fas fa-edit"></i>

                    @L["RegisterButton"]

                </a>

            </div>
        </div>
    </section>

    <section class="clubs-section">
        <div class="clubs-container">

            <div class="club-card aventureros">
                <div class="club-bg">
                    <img src="/img/Clubes/Aventutero.png" alt="@L["AdventurersAlt"]" />
                    <div class="club-overlay"></div>

                    <div class="club-info">
                        <div class="club-icon">
                            <i class="fas fa-star"></i>
                        </div>

                        <h2>@L["AdventurersTitle"]</h2>

                        <span class="age-range">
                            <i class="fas fa-user"></i>
                            @L["AdventurersAge"]
                        </span>

                        <p>@L["AdventurersDescription"]</p>


                        <div class="club-features">

                            <span><i class="fas fa-book-bible"></i> @L["AdventurersFeature1"]</span>

                            <span><i class="fas fa-palette"></i> @L["AdventurersFeature2"]</span>

                            <span><i class="fas fa-running"></i> @L["AdventurersFeature3"]</span>

                            <span><i class="fas fa-music"></i> @L["AdventurersFeature4"]</span>

                            <span><i class="fas fa-leaf"></i> @L["AdventurersFeature5"]</span>

                            <span><i class="fas fa-hands-helping"></i> @L["AdventurersFeature6"]</span>

                        </div>
                    </div>
                </div>

                <div class="club-footer">
                    <i class="far fa-clock"></i>
                    <strong>@L["Meetings"] @L["MeetingTime"]</strong>
                </div>
            </div>

            <div class="club-card conquistadores">
                <div class="club-bg">
                    <img src="/img/Clubes/Conquistadores.png" alt="@L["PathfindersAlt"]" />
                    <div class="club-overlay"></div>

                    <div class="club-info">
                        <div class="club-icon">
                            <i class="fas fa-shield-alt"></i>
                        </div>

                        <h2>@L["PathfindersTitle"]</h2>

                        <span class="age-range">
                            <i class="fas fa-user"></i>
                            @L["PathfindersAge"]
                        </span>

                        <p>@L["PathfindersDescription"]</p>


                        <div class="club-features">

                            <span><i class="fas fa-medal"></i> @L["PathfindersFeature1"]</span>

                            <span><i class="fas fa-campground"></i> @L["PathfindersFeature2"]</span>

                            <span><i class="fas fa-hands-helping"></i> @L["PathfindersFeature3"]</span>

                            <span><i class="fas fa-futbol"></i> @L["PathfindersFeature4"]</span>

                            <span><i class="fas fa-leaf"></i> @L["PathfindersFeature5"]</span>

                            <span><i class="fas fa-user-tie"></i> @L["PathfindersFeature6"]</span>

                        </div>

                    </div>
                </div>

                <div class="club-footer">
                    <i class="far fa-clock"></i>
                    <strong>@L["Meetings"] @L["MeetingTime"]</strong>
                </div>
            </div>

            <div class="club-card cadetes">
                <div class="club-bg">
                    <img src="/img/Clubes/Cadetes.png" alt="@L["CadetsAlt"]" />
                    <div class="club-overlay"></div>

                    <div class="club-info">
                        <div class="club-icon">
                            <i class="fas fa-flag"></i>
                        </div>

                        <h2>@L["CadetsTitle"]</h2>

                        <span class="age-range">
                            <i class="fas fa-users"></i>
                            @L["CadetsAge"]
                        </span>

                        <p>@L["CadetsDescription"]</p>


                        <div class="club-features">

                            <span><i class="fas fa-user-tie"></i> @L["CadetsFeature1"]</span>

                            <span><i class="fas fa-cross"></i> @L["CadetsFeature2"]</span>

                            <span><i class="fas fa-book-open"></i> @L["CadetsFeature3"]</span>

                            <span><i class="fas fa-church"></i> @L["CadetsFeature4"]</span>

                            <span><i class="fas fa-hands-helping"></i> @L["CadetsFeature5"]</span>

                            <span><i class="fas fa-briefcase"></i> @L["CadetsFeature6"]</span>

                        </div>
                    </div>
                </div>

                <div class="club-footer">
                    <i class="far fa-clock"></i>
                    <strong>@L["Meetings"] @L["MeetingTime"]</strong>
                </div>
            </div>

        </div>
    </section>

    @if (leaders != null && leaders.Any())
    {
        <section class="clubes-leadership">
            <div class="leadership-container">

                <div class="leadership-title-card">
                    <div class="leadership-icon">
                        <i class="fas fa-users"></i>
                    </div>

                    <div>
                        <h3>@L["LeadershipTitle"]</h3>
                        <span></span>
                    </div>
                </div>

                @foreach (var leader in leaders)
                {
                    <div class="leader-item">
                        <div class="leader-photo">
                            <img src="@leader.DisplayPhoto" alt="@leader.FullName" />
                        </div>

                        <div class="leader-info">
                            <h3>@leader.FullName</h3>
                            <p>@leader.Position</p>
                            <span></span>
                        </div>
                    </div>
                }

            </div>
        </section>
    }

</div>

@code {
    private List<Leadership> leaders = new();

    protected override async Task OnInitializedAsync()
    {
        var allLeaders = await LeadershipService.GetAllLeadershipAsync();

        leaders = allLeaders
            .Where(l => l.IsActive &&
                       !string.IsNullOrEmpty(l.Position) &&
                       (l.Position.Contains("Aventureros", StringComparison.OrdinalIgnoreCase) ||
                        l.Position.Contains("Conquistadores", StringComparison.OrdinalIgnoreCase) ||
                        l.Position.Contains("Cadetes", StringComparison.OrdinalIgnoreCase)))
            .OrderBy(l => l.DisplayOrder)
            .ToList();
    }
}