@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.Extensions.Localization
@using IASD_Magnolia.Services
@using IASD_Magnolia.Components.Shared
@using IASD_Magnolia.Resources
@inject IStringLocalizer<SharedResource> L

<header class="header">
    <div class="header-container">
        <div class="logo-container">
            <a href="/">
                <img src="/img/Logo2.png" alt="@L["Footer.ChurchName"] - Magnolia" class="logo-image" />
            </a>
        </div>
        <nav>
            <ul class="nav-menu">
                <li><NavLink href="/" Match="NavLinkMatch.All" ActiveClass="active">@L["Nav.Home"]</NavLink></li>
                <li><NavLink href="/sobre-nosotros" ActiveClass="active">@L["Nav.AboutUs"]</NavLink></li>
                <li><NavLink href="/ministerios" ActiveClass="active">@L["Nav.Ministries"]</NavLink></li>
                <li><NavLink href="/recursos" ActiveClass="active">@L["Nav.Resources"]</NavLink></li>
                <li><NavLink href="/eventos" ActiveClass="active">@L["Nav.Events"]</NavLink></li>
                <li><NavLink href="/clubes" ActiveClass="active">@L["Nav.Club"]</NavLink></li>
            </ul>
        </nav>

        <div class="header-actions">
            <LanguageSelector />
            <UserMenu />
        </div>
    </div>
</header>

<main>
    @Body
</main>

<footer class="footer">
    <div class="footer-container">
        <div class="footer-brand">
            <img src="/img/FooterLogo.png" alt="IASD Magnolia" class="footer-logo" />
            <h2>@L["Footer.ChurchName"]</h2>
            <p class="footer-location">@L["Footer.Location"]</p>
            <p class="footer-description">@L["Footer.Description"]</p>

            <div class="footer-social">
                <a href="https://www.facebook.com/people/IASDMagnolia/100083356866181/" target="_blank" aria-label="Facebook">
                    <i class="fab fa-facebook-f"></i>
                </a>
                <a href="https://www.instagram.com/magnolias_youth/" target="_blank" aria-label="Instagram">
                    <i class="fab fa-instagram"></i>
                </a>
                <a href="https://www.youtube.com/@@iasdmagnolia2437/videos" target="_blank" aria-label="YouTube">
                    <i class="fab fa-youtube"></i>
                </a>
                <a href="https://wa.me/17875053830" target="_blank" aria-label="WhatsApp">
                    <i class="fab fa-whatsapp"></i>
                </a>
            </div>
        </div>

        <div class="footer-links-section">
            <h3>@L["Footer.QuickLinks"]</h3>
            <ul>
                <li><a href="/"><i class="fas fa-chevron-right"></i> @L["Nav.Home"]</a></li>
                <li><a href="/sobre-nosotros"><i class="fas fa-chevron-right"></i> @L["Nav.AboutUs"]</a></li>
                <li><a href="/ministerios"><i class="fas fa-chevron-right"></i> @L["Nav.Ministries"]</a></li>
                <li><a href="/eventos"><i class="fas fa-chevron-right"></i> @L["Nav.Events"]</a></li>
                <li><a href="/recursos"><i class="fas fa-chevron-right"></i> @L["Nav.Resources"]</a></li>
                <li><a href="/clubes"><i class="fas fa-chevron-right"></i> @L["Nav.Club"]</a></li>
            </ul>
        </div>

        <div class="footer-contact-section">
            <h3>@L["Footer.ContactUs"]</h3>

            <div class="contact-item">
                <div class="contact-icon">
                    <i class="fas fa-phone-alt"></i>
                </div>
                <span>787-505-3830</span>
            </div>

            <div class="contact-item">
                <div class="contact-icon">
                    <i class="fas fa-envelope"></i>
                </div>
                <span>info@@iasdmagnolia.org</span>
            </div>

            <div class="contact-item">
                <div class="contact-icon">
                    <i class="fas fa-map-marker-alt"></i>
                </div>
                <div>
                    <span>@L["Footer.Address1"]</span><br />
                    <span>@L["Footer.Address2"]</span>
                </div>
            </div>

            <a href="https://maps.google.com/?q=18.380254272796076,-66.16873116802577" target="_blank" class="btn-map">
                <i class="fas fa-map-marked-alt"></i> @L["Footer.ViewGoogleMaps"]
            </a>
        </div>

        <div class="footer-map-section">
            <h3>@L["Footer.Location2"]</h3>

            <div class="map-container">
                <iframe src="https://www.google.com/maps?q=18.380254272796076,-66.16873116802577&z=17&output=embed"
                        width="100%"
                        height="200"
                        style="border:0; border-radius:10px;"
                        allowfullscreen
                        loading="lazy"
                        referrerpolicy="no-referrer-when-downgrade">
                </iframe>
            </div>

            <p class="map-text">
                @L["Footer.MapText"] <i class="fas fa-map-pin"></i>
            </p>
        </div>
    </div>

    <div class="footer-bottom">
        <p>@L["Footer.Copyright"]</p>
        <p class="footer-love"><i class="fas fa-heart"></i> @L["Footer.LoveMessage"]</p>
    </div>
</footer>

<div id="blazor-error-ui">
    @L["Error.UnhandledError"]
    <a href="" class="reload">@L["Error.Reload"]</a>
    <a class="dismiss">✖</a>
</div>


